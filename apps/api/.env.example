# Example environment configuration for the API. Copy to `.env` for local
# development. Never commit a real `.env` or a real key.

# Jira API-token credential encryption key (AES-256-GCM).
#
# Must be a base64-encoded value that decodes to exactly 32 bytes. Generate one
# with Node.js:
#
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
#
# Leave this unset to run the application without Jira connection support; the
# Jira connection endpoints then return HTTP 503 (jira_not_configured) while
# health, login, logout, and session restoration keep working. A value that is
# present but does not decode to 32 bytes fails startup with a configuration
# error.
JIRA_CREDENTIAL_ENCRYPTION_KEY=
